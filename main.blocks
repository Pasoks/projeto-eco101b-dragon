k></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement><next><block type="typescript_statement"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="setTimeout(function () {" line1="        if (faseAtual &lt; 3 || transicaoEmAndamento || noMenu) {" line2="            return" line3="        }" line4="        Sons.ataque1Dg2()" line5="        for (let o = 0; o &lt; 4; o++) {" line6="            let e2 = sprites.create(imgExplosaoDragao, SpriteKind.TipoExplosao)" line7="            e2.setPosition(posX[o], posY[o])" line8="            e2.setFlag(SpriteFlag.GhostThroughWalls, true)" line9="            e2.lifespan = 300" line10="        }" line11="    }, 2000)" numlines="12"></mutation><next><block type="typescript_statement"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="setTimeout(function () {" line1="        if (faseAtual &lt; 3 || transicaoEmAndamento || noMenu) {" line2="            return" line3="        }" line4="        executandoAtaqueDragao = false" line5="        acaoDoBoss = &quot;parado&quot;" line6="        frameAtual = 0" line7="    }, 2500)" numlines="8"></mutation></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement></block><block type="function_definition" x="4715" y="15173"><mutation name="IniciarFaseSelecionada" functionid="6+M+bm758ol!Rc4*AMVZ"></mutation><field name="function_name">IniciarFaseSelecionada</field><statement name="STACK"><block type="gamesetbackgroundimage"><value name="img"><shadow type="background_image_picker"><field name="img"></field></shadow><block type="variables_get"><field name="VAR" id="XtQ,2UK(#l}p?7aI.6Iq">telaPreta</field></block></value><next><block type="gamesetbackgroundcolor"><value name="color"><shadow type="colorindexpicker"><field name="index">0</field></shadow></value><next><block type="device_pause"><value name="pause"><shadow type="timePicker"><field name="ms">100</field></shadow></value><next><block type="controls_if"><mutation elseif="1"></mutation><value name="IF0"><shadow type="logic_boolean"><field name="BOOL">TRUE</field></shadow><block type="logic_compare"><field name="OP">EQ</field><value name="A"><shadow type="math_number"><field name="NUM">0</field></shadow><block type="variables_get"><field name="VAR" id=")`WyJiE6`iPC$zH8dY]|">faseAtual</field></block></value><value name="B"><shadow type="math_number"><field name="NUM">2</field></shadow></value></block></value><statement name="DO0"><block type="variables_set"><field name="VAR" id=")TzP+RUt-2g%(})#vLH5">loreDragao</field><value name="VALUE"><shadow type="math_number"><field name="NUM">0</field></shadow><block type="lists_create_with" inline="false"><mutation items="4" horizontalafter="3"></mutation><value name="ADD0"><shadow type="text"><field name="TEXT">Apos a luta mais esquisita da sua vida, voce se depara com um dragao gigante vindo em sua direcao.</field></shadow></value><value name="ADD1"><shadow type="text"><field name="TEXT">"Pode parar de se esconder pequenino, sei que esta ai." - Diz o Dragao</field></shadow></value><value name="ADD2"><shadow type="text"><field name="TEXT">"Nao tinha essa intencao! Vim aqui para roubar seu tesouro!" - Voce diz.</field></shadow></value><value name="ADD3"><shadow type="text"><field name="TEXT">"Primeiro, rouba minha sobremesa, agora meu tesouro? Venha entao, Anao!"</field></shadow></value></block></value><next><block type="pxt_controls_for_of"><value name="VAR"><block type="variables_get_reporter"><field name="VAR" id="nJ^F_=}X=jb#AB|@HY{/">texto</field></block></value><value name="LIST"><block type="variables_get"><field name="VAR" id=")TzP+RUt-2g%(})#vLH5">loreDragao</field></block></value><statement name="DO"><block type="game_show_long_text"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text"><field name="TEXT"></field></shadow><block type="variables_get"><field name="VAR" id="nJ^F_=}X=jb#AB|@HY{/">texto</field></block></value></block></statement></block></next></block></statement><value name="IF1"><shadow type="logic_boolean"><field name="BOOL">TRUE</field></shadow><block type="logic_compare"><field name="OP">EQ</field><value name="A"><shadow type="math_number"><field name="NUM">0</field></shadow><block type="variables_get"><field name="VAR" id=")`WyJiE6`iPC$zH8dY]|">faseAtual</field></block></value><value name="B"><shadow type="math_number"><field name="NUM">3</field></shadow></value></block></value><statement name="DO1"><block type="variables_set"><field name="VAR" id=")TzP+RUt-2g%(})#vLH5">loreDragao</field><value name="VALUE"><shadow type="math_number"><field name="NUM">0</field></shadow><block type="lists_create_with" inline="false"><mutation items="4" horizontalafter="3"></mutation><value name="ADD0"><shadow type="text"><field name="TEXT">Após a segunda fase exaustiva, o dragão recua. Suas escamas antes brilhantes agora estão rachadas. O chão da caverna treme a cada respiracao pesada da fera, e fumaça negra inunda o local. Ele não está mais brincando com a comida.</field></shadow></value><value name="ADD1"><shadow type="text"><field name="TEXT">"INACEITÁVEL!!! Como um inseto ousa me ferir?!" - Ruge o Dragão.</field></shadow></value><value name="ADD2"><shadow type="text"><field name="TEXT">"Eu já avisei! Os juros do meu banco doem muito mais que o seu fogo! Eu PRECISO desse ouro!" - Você grita, sem ter mais nada a perder.</field></shadow></value><value name="ADD3"><shadow type="text"><field name="TEXT">"Maldita seja sua audácia!!! Maldito seja seu diploma!!!" - Grita o Dragão, coberto por chamas negras - "Que o banco venha recolher suas CINZAS!!!"</field></shadow></value></block></value><next><block type="pxt_controls_for_of"><value name="VAR"><block type="variables_get_reporter"><field name="VAR" id=")HAa?(-qzZ$fg}ws54.+">texto2</field></block></value><value name="LIST"><block type="variables_get"><field name="VAR" id=")TzP+RUt-2g%(}