 type="logic_boolean"><field name="BOOL">TRUE</field></shadow><block type="variables_get"><field name="VAR" id="TJ$Z%@D7{(w*uQ1+g{9$">introTocada</field></block></value></block></value><statement name="DO0"><block type="function_call"><mutation name="Intro" functionid="c3/vf/AcrbgKpU;ZauQt"></mutation><next><block type="variables_set"><field name="VAR" id="TJ$Z%@D7{(w*uQ1+g{9$">introTocada</field><value name="VALUE"><shadow type="math_number"><field name="NUM">0</field></shadow><block type="logic_boolean"><field name="BOOL">TRUE</field></block></value></block></next></block></statement><next><block type="function_call"><mutation name="MostrarMenuSelecao" functionid="sXY8|=!kwGdXb7FyUK_v"></mutation></block></next></block></statement></block><block type="function_definition" x="11155" y="15173"><mutation name="Intro" functionid="c3/vf/AcrbgKpU;ZauQt"></mutation><field name="function_name">Intro</field><statement name="STACK"><block type="gamesetbackgroundcolor"><value name="color"><shadow type="colorindexpicker"><field name="index">15</field></shadow></value><next><block type="typescript_statement"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="Sons.musicaIntro()" numlines="1"></mutation><next><block type="typescript_statement"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="let text = &quot;  THE GREDDY DRAGON\n\nApos os 5 anos mais\nsombrios de sua historia,\napos incontaveis desafios,\nlongas e excruciantes\nhoras de sofrimento, voce\nfinalmente tem seu tao\nansiado DIPLOMA DE ENSINO\nSUPERIOR.\n\n\&quot;Nada pode me parar!!!\&quot;\n- Diz.\n\nAte que voce se lembra do\nseu EMPRESTIMO ESTUDANTIL.\n5 anos sem preocupacao,\nmas agora seu pior\npesadelo se tornou\nrealidade: os juros\ntransformaram um simples\nemprestimo em uma fortuna\nque ninguem no mundo\npoderia pagar.\n\nNo bar, afundando suas\nmagoas com seu ex colega\nque ja fundou uma empresa\ne e CEO, voces conversam:\n\n\&quot;E impossivel!\nSimplesmente impossivel!\&quot;\n- Voce diz.\n\n\&quot;Nem eu tenho todo esse\ndinheiro. Talvez so um\ndragao daquelas historias\nde crianca tenha dinheiro\nnesse nivel em seu ninho\&quot;\n- Falou seu amigo.\n\nEnquanto seu amigo ria da\npiada que fez, sua cabeca\nja cheia de problemas\nforma sua ideia genial.\n\&quot;O que tenho a perder?\&quot;\n- Pensa.\n\nEntao, com uma ideia na\ncabeca e equipamento\nroubado, voce parte para\no suposto ninho do dragao.\n\nVoce se depara com a\nentrada de uma caverna\ngigante. Apos entrar,\nse depara com uma coisa\nque tambem so tinha visto\nem historias: um Slime.&quot;" numlines="1" declaredvars="text"></mutation><next><block type="variables_set"><field name="VAR" id="M[pTr$(`|H{azVIJ3s=H">linhas</field><value name="VALUE"><shadow type="math_number"><field name="NUM">0</field></shadow><block type="string_split"><value name="this"><shadow type="text"><field name="TEXT"></field></shadow><block type="variables_get"><field name="VAR" id="rdR,r7p*|O5TgWkW]nPI">text</field></block></value><value name="separator"><block type="typescript_expression"><field name="EXPRESSION">"\n"</field></block></value></block></value><next><block type="variables_set"><field name="VAR" id="hbgw%h%IY}Wd@iJIPS@,">alturaDaLinha</field><value name="VALUE"><shadow type="math_number"><field name="NUM">12</field></shadow></value><next><block type="variables_set"><field name="VAR" id="PV5eShvZw5K-$-;fc(7o">textHeight</field><value name="VALUE"><shadow type="math_number"><field name="NUM">0</field></shadow><block type="math_arithmetic"><field name="OP">MULTIPLY</field><value name="A"><shadow type="math_number"><field name="NUM">0</field></shadow><block type="lists_length"><value name="VALUE"><block type="variables_get"><field name="VAR" id="M[pTr$(`|H{azVIJ3s=H">linhas</field></block></value></block></value><value name="B"><shadow type="math_number"><field name="NUM">0</field></shadow><block type="variables_get"><field name="VAR" id="hbgw%h%IY}Wd@iJIPS@,">alturaDaLinha</field></block></value></block></value><nex