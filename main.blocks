imePicker" id="e#4|QkwY3+z,A.;TLvGV"><field name="ms">100</field></shadow></value><next><block type="controls_if" id="@7_-Hf~i{i:k=_:?O(y!"><mutation elseif="1"></mutation><value name="IF0"><shadow type="logic_boolean" id="7_BEW;;#JFx8B)%P^~UT"><field name="BOOL">TRUE</field></shadow><block type="logic_compare" id="!v`3Va#%(U6#tHCp7.Ux"><field name="OP">EQ</field><value name="A"><shadow type="math_number" id="pYD8TFr+B%1l4R1?^GvR"><field name="NUM">0</field></shadow><block type="variables_get" id="a(.hQ*jeKacfgxza?~B*"><field name="VAR" id="mpT?Vi.qF|5l^)H7C)EM">faseAtual</field></block></value><value name="B"><shadow type="math_number" id="VX,W72f8ZdDOu/gEyYs0"><field name="NUM">2</field></shadow></value></block></value><statement name="DO0"><block type="variables_set" id="@Y/2d-Vow0O{0o/)IWbW"><field name="VAR" id="1y%qqZw;f=#r,sgifx2@">loreDragao</field><value name="VALUE"><shadow type="math_number" id="]GiJp9:W{;!u2__d-J;u"><field name="NUM">0</field></shadow><block type="lists_create_with" id="~|;gym3:bKeu+p:n7lR3" inline="false"><mutation items="4" horizontalafter="3"></mutation><value name="ADD0"><shadow type="text" id="PwHE!Ut(4mx9,S{84,N)"><field name="TEXT">Apos a luta mais esquisita da sua vida, voce se depara com um dragao gigante vindo em sua direcao.</field></shadow></value><value name="ADD1"><shadow type="text" id="~2R,U,`n):;xKwH[vL)@"><field name="TEXT">"Pode parar de se esconder pequenino, sei que esta ai." - Diz o Dragao</field></shadow></value><value name="ADD2"><shadow type="text" id="oW++X*T,{FQAwqJXsfRq"><field name="TEXT">"Nao tinha essa intencao! Vim aqui para roubar seu tesouro!" - Voce diz.</field></shadow></value><value name="ADD3"><shadow type="text" id="*b1$Ibl_mdU(3+vaWFv="><field name="TEXT">"Primeiro, rouba minha sobremesa, agora meu tesouro? Venha entao, Anao!"</field></shadow></value></block></value><next><block type="pxt_controls_for_of" id="@)MngM8L-KN*4$9hu*RB"><value name="VAR"><block type="variables_get_reporter" id="*I?1}l%VX@r:`PsAt**)" deletable="false"><field name="VAR" id="IIEZZys#H5d~m/jl0w.D">texto</field></block></value><value name="LIST"><block type="variables_get" id="SviC2xwQ]O6?HJWj~zh{"><field name="VAR" id="1y%qqZw;f=#r,sgifx2@">loreDragao</field></block></value><statement name="DO"><block type="game_show_long_text" id="@1YT`Xu@]m]a6[wXlX:)"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="3-),wPudVnX+;swK!aSF"><field name="TEXT"></field></shadow><block type="variables_get" id="RNOMyB`JAu39E_D[-F^a"><field name="VAR" id="IIEZZys#H5d~m/jl0w.D">texto</field></block></value></block></statement></block></next></block></statement><value name="IF1"><shadow type="logic_boolean" id="3LCKgq5LHmt%j|B~vccJ"><field name="BOOL">TRUE</field></shadow><block type="logic_compare" id="XWI/y6{t(lSEAi)JmZBn"><field name="OP">EQ</field><value name="A"><shadow type="math_number" id="db8n88TZ7XNKW:]UZ5@@"><field name="NUM">0</field></shadow><block type="variables_get" id="0H~rRD]~Ei+0vtfQ*C^j"><field name="VAR" id="mpT?Vi.qF|5l^)H7C)EM">faseAtual</field></block></value><value name="B"><shadow type="math_number" id="L]_vrG5L/.(+sBmkDtYU"><field name="NUM">3</field></shadow></value></block></value><statement name="DO1"><block type="variables_set" id="@/PmeB8#.v*{+vi`;EcU"><field name="VAR" id="1y%qqZw;f=#r,sgifx2@">loreDragao</field><value name="VALUE"><shadow type="math_number" id="E@isC-~8f)/Rt(82jS9D"><field name="NUM">0</field></shadow><block type="lists_create_with" id="Vk`70k_}GS5QA$M^c]X_" inline="false"><mutation items="4" horizontalafter="3"></mutation><value name="ADD0"><shadow type="text" id="S:YVY_Woe`Dzj4$zJ]0Q"><field name="TEXT">Após a segunda fase exaustiva, o dragão recua. Suas escamas antes brilhantes agora estão rachadas. O chão da caverna treme a cada respiracao pesada da fera, e fumaça negra inunda o local. Ele não está mais brincando com a comida.</field></shadow></value><value name="ADD1"><shadow type="text" id="Z4u$UQf]Pw0Cd.==kFs8"><field name="TEXT">"INACEITÁVEL!!! Como um inseto ousa me ferir?!" - Ruge o Dragão.</field></shadow></value><value name="ADD2"><shadow type="text" id="qy?)|_Dgr=NyY(mn.T|g"><field name="TEXT">"Eu já avisei! Os juros do meu banco doem muito mais que o seu fogo! Eu PRECISO desse ouro!" - Você grita, sem ter mais nada a perder.</field></shadow></value><value name="ADD3"><shadow type="text" id="n7,9k~zwtVx{?,`CqqN2"><field name="TEXT">"Maldita seja sua audácia!!! Maldito seja seu diploma!!!" - Grita o Dragão, coberto por chamas negras - "Que o banco venha recolher suas CINZAS!!!"</field></shadow></value></block></value><next><block type="pxt_controls_for_of" id=";F,2jLpfjwOg7dz8@Qg3"><value name="VAR"><block type="variables_get_reporter" id="KKL+T4n3#=}NSI~yBz_:" deletable="false"><field name="VAR" id="H[0%)E3iL8qwyi@lYZTf">texto2</field></block></value><value name="LIST"><block type="variables_get" id="4pq{*3Qg[CnuLa;w.{.c"><field name="VAR" id="1y%qqZw;f=#r,sgifx2@">loreDragao</field></block></value><statement name="DO"><block type="game_show_long_text" id="93Pm60[`.nCp$T17=QMy"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="]y+5?F/o4d~7pb^GtrMS"><field name="TEXT"></field></shadow><block type="variables_get" id="-#h_/FZ_,h`#X2qP}`oU"><field name="VAR" id="H[0%)E3iL8qwyi@lYZTf">texto2</field></block></value></block></statement></block></next></block></statement><next><block type="controls_if" id="37$Ho{G,=tJ31Vuzc5Im"><value name="IF0"><shadow type="logic_boolean" id="FR+RHZgrj#~RssP3SrCo"><field name="BOOL">TRUE</field></shadow><block type="logic_compare" id="gVBf^(hk*6hwbE}}W}Ck"><field name="OP">EQ</field><value name="A"><shadow type="math_number" id="j`39,gUz`W-cf^JoX$d%"><field name="NUM">0</field></shadow><block type="variables_get" id="tb)h2#YM.nby?r,R;~P="><field name="VAR" id="mpT?Vi.qF|5l^)H7C)EM">faseAtual</field></block></value><value name="B"><shadow type="math_number" id="o3d!L|HR$1tO[r.[AFCl"><field name="NUM">1